    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "graphql": "^16.9.0",
    "graphql-request": "^7.1.0",
    "lightweight-charts": "^5.1.0",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "p-limit": "^6.1.0",
    "p-retry": "^6.2.0",
    "viem": "^2.21.54",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
