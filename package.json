  "description": "An attested autonomous DeFi operator that converts social sentiment and on-chain signals into permission-gated trade execution on Base.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/loop/index.ts",
    "start": "tsx src/loop/index.ts",
    "build": "tsc --noEmit",
